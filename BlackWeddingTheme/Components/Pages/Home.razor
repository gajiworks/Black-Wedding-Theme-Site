@page "/"
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject IConfiguration Configuration
@implements IAsyncDisposable

<PageTitle>Melvin &amp; Trisha | 10.11.2027</PageTitle>

<header class="site-header">
    <nav class="navbar shell" aria-label="Main navigation">
        <a class="brand" href="#home">Luna &amp; Lace Events</a>
    </nav>
</header>

<main>
    <section class="hero" id="home">
        <div class="hero-layout shell">
            <div class="hero-content">
                <p class="eyebrow">A black-tie celebration</p>
                <h1><span class="hero-name hero-name-first">Melvin</span><span class="hero-ampersand">&amp;</span><span class="hero-name hero-name-second">Trisha</span></h1>
                <div class="editorial-divider" aria-hidden="true"><i></i><b></b><i></i></div>
                <div class="hero-finale"><p class="wedding-date">10.11.2027</p><p class="hero-tagline">Forever starts here.</p></div>
            </div>
            <div class="hero-image-frame">
                <img class="hero-image" src="/images/wedding/hero-romantic-pastel.png" alt="Melvin and Trisha, the wedding couple" />
            </div>
        </div>
        <a class="hero-scroll-cue" href="#story" aria-label="Scroll to Our Story"><span>Scroll</span><i aria-hidden="true"></i></a>
    </section>

    <section class="section shell story-section" id="story">
        <div class="section-heading" data-reveal><p class="eyebrow">The beginning</p><h2>Our Story</h2></div>
        <div class="story-layout">
            <div class="story-copy" data-reveal="left">
                <p class="story-label">Our Journey</p>
                <h3>It was always you.</h3>
                <div class="story-divider" aria-hidden="true"><span></span><b></b></div>
                <p>From simple moments to unforgettable memories, Melvin and Trisha&rsquo;s story became a journey of love, trust, and choosing each other every day.</p>
                <p>Through every season, they found joy in the little things and strength in each other.</p>
                <a class="story-button" href="#details">Our Journey</a>
            </div>
            <div class="story-image-frame" data-reveal="right" style="--reveal-delay: .14s">
                <img class="story-image" src="/images/wedding/story-couple-portrait.png" alt="Melvin and Trisha together" loading="lazy" />
            </div>
        </div>
    </section>

    <div class="section-divider" aria-hidden="true"><span></span><b>&diams;</b><span></span></div>

    <section class="section details-section" id="details"><div class="shell">
        <div class="section-heading" data-reveal><p class="eyebrow">Save the date</p><h2>Wedding Details</h2></div>
        <div class="detail-grid">
            <article class="detail-card" data-reveal style="--reveal-delay: 0s">
                <div class="detail-icon" aria-hidden="true">
                    <svg viewBox="0 0 48 48" focusable="false"><path d="M8 41h32M11 41V22h26v19M18 41V29h12v12M8 22h32L24 9 8 22Zm13-5V7h6v10M16 26h3m10 0h3" /></svg>
                </div>
                <p class="detail-label">Wedding Ceremony</p>
                <h3>Ceremony</h3>
                <div class="detail-divider" aria-hidden="true"><span></span><b></b><span></span></div>
                <p class="detail-time">4:00 PM</p><p class="detail-place">St. Peter Parish</p><p class="detail-meta">Quezon City</p>
            </article>
            <article class="detail-card featured" data-reveal style="--reveal-delay: .15s; --reveal-end-transform: translateY(-10px)">
                <div class="detail-icon" aria-hidden="true">
                    <svg viewBox="0 0 48 48" focusable="false"><path d="m14 8 4 14c1 4 3 6 6 6s5-2 6-6L34 8H14Zm3 11h14M24 28v12m-6 0h12M9 10l3 2m27-2-3 2M12 5l2 2m22-2-2 2" /></svg>
                </div>
                <p class="detail-label">The Reception</p>
                <h3>Reception</h3>
                <div class="detail-divider" aria-hidden="true"><span></span><b></b><span></span></div>
                <p class="detail-time">6:30 PM</p><p class="detail-place">The Manor at Camp John Hay</p><p class="detail-meta">Baguio City</p>
            </article>
            <article class="detail-card" data-reveal style="--reveal-delay: .30s">
                <div class="detail-icon" aria-hidden="true">
                    <svg viewBox="0 0 48 48" focusable="false"><path d="M10 13h28v27H10V13Zm0 9h28M17 8v10m14-10v10M17 28h5m4 0h5m-14 6h5m4 0h5" /></svg>
                </div>
                <p class="detail-label">Save The Date</p>
                <h3>Date</h3>
                <div class="detail-divider" aria-hidden="true"><span></span><b></b><span></span></div>
                <p class="detail-place">Saturday</p>
                <p class="detail-meta">October 11, 2027</p>
            </article>
        </div>
    </div></section>

    <div class="section-divider" aria-hidden="true"><span></span><b>&diams;</b><span></span></div>

    <section class="section gallery-section" id="gallery">
        <div class="shell">
            <div class="section-heading" data-reveal><p class="eyebrow">Moments in black &amp; white</p><h2>Gallery</h2></div>
            <div class="gallery-grid">
                @for (var index = 0; index < GalleryImages.Length; index++)
                {
                    var image = GalleryImages[index];
                    var revealDelay = $"--reveal-delay: {Math.Min(index * 0.08, 0.48):0.00}s";
                    <button class="gallery-card" type="button" data-reveal style="@revealDelay" @onclick="() => OpenGalleryImage(image)" aria-label="Open @image.Alt">
                        <img class="gallery-photo" src="@image.Source" alt="@image.Alt" loading="lazy" />
                    </button>
                }
            </div>
        </div>
    </section>

    <div class="section-divider" aria-hidden="true"><span></span><b>&diams;</b><span></span></div>

    <section class="section rsvp-section" id="rsvp">
        <div class="rsvp-card shell-narrow" data-reveal>
            <div class="rsvp-seal" aria-hidden="true"><span>M</span><i>&amp;</i><span>T</span></div>
            <div class="section-heading"><p class="eyebrow">The favor of your reply</p><h2>RSVP</h2></div>
            <p class="rsvp-intro">Kindly respond on or before September 11, 2027.</p>
            <form class="rsvp-form" action="https://api.staticforms.dev/submit" method="post" novalidate>
                <!-- The real StaticForms API key is injected during deployment using the STATIC_FORMS_API_KEY secret. -->
                <input type="hidden" name="apiKey" value="@StaticFormsApiKey" />
                <input type="hidden" name="subject" value="New Melvin and Trisha Wedding RSVP" />
                <label>Full Name<input type="text" name="name" placeholder="Your name" autocomplete="name" required /></label>
                <label>Message<textarea name="message" rows="4" placeholder="Share a little note" required></textarea></label>
                <input class="honeypot-field" type="text" name="honeypot" tabindex="-1" autocomplete="off" aria-hidden="true" />
                <button class="button" type="submit" data-submit-label="Yes, I’ll Be There">Yes, I&rsquo;ll Be There</button>
                <p class="rsvp-form-status" role="status" aria-live="polite"></p>
            </form>
        </div>
    </section>
</main>

<footer class="site-footer" id="contact">
    <div class="footer-monogram" aria-hidden="true"><span></span><b>M &amp; T</b><span></span></div>
    <p>Thank you for being part of our day.</p>
    <small>October 11, 2027</small>
</footer>

@if (SelectedGalleryImage is not null)
{
    <div class="gallery-modal" role="dialog" aria-modal="true" aria-label="Wedding gallery photo preview" @onclick="CloseGalleryImage">
        <div class="gallery-modal-content" @onclick:stopPropagation="true">
            <button class="gallery-modal-close" type="button" aria-label="Close gallery preview" @onclick="CloseGalleryImage">&times;</button>
            <img src="@SelectedGalleryImage.Source" alt="@SelectedGalleryImage.Alt" />
        </div>
    </div>
}

<div class="rsvp-success-modal" id="rsvp-success-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="rsvp-success-title">
    <div class="rsvp-success-panel">
        <div class="rsvp-success-header">
            <h2 id="rsvp-success-title">RSVP Sent</h2>
            <button class="rsvp-success-close" type="button" aria-label="Close RSVP confirmation">&times;</button>
        </div>
        <div class="rsvp-success-content">
            <p>Thank you for your response! We&rsquo;re delighted to celebrate this special day with you.</p>
            <button class="button rsvp-success-close" type="button">Done</button>
            <small>Your RSVP has been received successfully.</small>
        </div>
    </div>
</div>

@code {
    private GalleryItem? SelectedGalleryImage { get; set; }
    private DotNetObjectReference<Home>? GalleryReference { get; set; }
    private bool IsInteractiveRenderInitialized { get; set; }
    private string StaticFormsApiKey => Configuration["STATIC_FORMS_API_KEY"] ?? "__STATIC_FORMS_API_KEY__";

    private static readonly GalleryItem[] GalleryImages =
    [
        new("/images/wedding/gallery-closeup-garden-path.png", "Melvin and Trisha wedding portrait"),
        new("/images/wedding/gallery-terrace.png", "Melvin and Trisha on the terrace"),
        new("/images/wedding/gallery-walking-garden.png", "Melvin and Trisha walking together"),
        new("/images/wedding/gallery-courtyard-building.png", "Melvin and Trisha in the courtyard"),
        new("/images/wedding/gallery-side-back-walk.png", "Melvin and Trisha wedding day moment"),
        new("/images/wedding/gallery-front-courtyard.png", "Melvin and Trisha formal portrait"),
        new("/images/wedding/wed-invitation.png", "Black tie wedding invitation detail")
    ];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("weddingMotion.init");
            await JS.InvokeVoidAsync("weddingRsvp.init");
            IsInteractiveRenderInitialized = true;
        }
    }

    private async Task OpenGalleryImage(GalleryItem image)
    {
        SelectedGalleryImage = image;
        GalleryReference ??= DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("weddingGallery.open", GalleryReference);
    }

    private async Task CloseGalleryImage()
    {
        SelectedGalleryImage = null;
        await JS.InvokeVoidAsync("weddingGallery.close");
        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task CloseGalleryFromEscape()
    {
        return CloseGalleryImage();
    }

    public async ValueTask DisposeAsync()
    {
        if (IsInteractiveRenderInitialized)
        {
            try
            {
                await JS.InvokeVoidAsync("weddingGallery.close");
            }
            catch (JSDisconnectedException)
            {
            }
        }

        GalleryReference?.Dispose();
    }

    private sealed record GalleryItem(string Source, string Alt);
}
